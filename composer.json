{
    "name": "abduns/laravel-gpx-reader",
    "description": "A Laravel package to read and work with GPX 1.1 files.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Abduns",
            "email": "abduns@example.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0"
    },
    "require-dev": {
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0",
        "orchestra/testbench": "^8.0|^9.0"
    },
    "autoload": {
        "psr-4": {
            "Dunn\\GpxReader\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dunn\\GpxReader\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Dunn\\GpxReader\\Providers\\GpxServiceProvider"
            ],
            "aliases": {
                "Gpx": "Dunn\\GpxReader\\Facades\\Gpx"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
